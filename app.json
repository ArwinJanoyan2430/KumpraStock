{
  "expo": {
    "name": "KumpraStock",
    "slug": "kstock",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/logo.png",

    "scheme": "kstock",

    "ios": {
      "bundleIdentifier": "com.arwinjanoyan.kumprastock",
      "supportsTablet": true
    },

    "android": {
      "package": "com.arwinjanoyan.kumprastock",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#E6F4FE"
      }
    },

    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/logo.png",
          "imageWidth": 180
        }
      ],
      "expo-router"
    ]
  }
}