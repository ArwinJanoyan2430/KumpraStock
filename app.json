{
  "expo": {
    "name": "KumpraStock",
    "slug": "kstock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "kstock",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.arwinjanoyan.kumprastock",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.arwinjanoyan.kumprastock",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/logo.png",
          "imageWidth": 180
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "50bc6c9b-b567-4ca1-989e-57d69cf56e7e"
      }
    }
  }
}
